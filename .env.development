# Shared dev config (committed, loaded by Next.js in development).
# Points at the team's self-hosted vLLM (OpenAI-compatible) endpoint.
# No real secret here: the server needs no auth, so the key is a placeholder.
#
# Override locally by creating .env.local (gitignored), which takes precedence.
# NOTE: the ngrok URL is ephemeral and changes when the tunnel restarts.

OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_MODEL=Qwen/Qwen2.5-32B-Instruct
OPENAI_API_KEY=not-needed
