# Copy this file to .env.local and fill in the values.

# --- Option A: OpenAI ---
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Option B: self-hosted OpenAI-compatible server (e.g. vLLM) ---
# Point at the server's /v1 base URL. API key is optional for most local servers.
OPENAI_BASE_URL=https://localhost:8000
OPENAI_MODEL=qwen2.5-32b
OPENAI_API_KEY=not-needed
